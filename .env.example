# ============================================
# DigiGram Pro — Environment Variables
# Copy this to .env and fill in your values
# ============================================

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://digigram:digigram_secret@localhost:5432/digigram_db

# ── JWT ───────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI (Gemini Vision) ───────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── File Uploads ──────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ── Frontend ──────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Postgres (used by docker-compose) ────────
POSTGRES_USER=digigram
POSTGRES_PASSWORD=digigram_secret
POSTGRES_DB=digigram_db
